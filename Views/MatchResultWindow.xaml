<Window x:Class="Ming_AutoClicker.Views.MatchResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="匹配结果"
        WindowStyle="None"
        Topmost="True"
        ResizeMode="NoResize"
        WindowState="Maximized"
        Background="Black"
        ShowInTaskbar="False"
        Focusable="True">

    <Canvas x:Name="MainCanvas">
        <!-- 屏幕截图背景 -->
        <Image x:Name="BackgroundImage" Stretch="Fill"/>

        <!-- 半透明遮罩 -->
        <Path x:Name="OverlayPath" Fill="#66000000"/>

        <!-- 匹配区域高亮（半透明填充） -->
        <Rectangle x:Name="HighlightRect"
                   Fill="#1A52D4A0"
                   Visibility="Collapsed"/>

        <!-- 匹配区域边框 -->
        <Rectangle x:Name="MatchBorder"
                   Stroke="#FF52D4A0"
                   StrokeThickness="3"
                   StrokeDashArray="8,4"
                   Visibility="Collapsed"/>

        <!-- 匹配中心十字线 -->
        <Line x:Name="CrossH" Stroke="#FF52D4A0" StrokeThickness="1" Visibility="Collapsed"
              StrokeDashArray="4,4" Opacity="0.7"/>
        <Line x:Name="CrossV" Stroke="#FF52D4A0" StrokeThickness="1" Visibility="Collapsed"
              StrokeDashArray="4,4" Opacity="0.7"/>

        <!-- 左上角信息面板 -->
        <Border x:Name="InfoPanel"
                Background="#E01A1A2E"
                BorderBrush="#FF52D4A0"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16,12"
                Visibility="Collapsed">
            <StackPanel>
                <!-- 标题栏 -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Ellipse Grid.Column="0" Width="10" Height="10" Fill="#FF52D4A0" Margin="0,0,8,0"
                             VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="✓ 匹配成功" Foreground="#FF52D4A0" FontWeight="SemiBold" FontSize="15"/>
                </Grid>

                <!-- 分隔线 -->
                <Border Background="#3352D4A0" Height="1" Margin="0,0,0,10"/>

                <!-- 详细信息 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="位　置" Foreground="#99FFFFFF" FontSize="12" Margin="0,0,16,6"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TxtPosition" Foreground="White" FontSize="13" FontFamily="Consolas" Margin="0,0,0,6"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="相似度" Foreground="#99FFFFFF" FontSize="12" Margin="0,0,16,6"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TxtSimilarity" Foreground="White" FontSize="13" FontFamily="Consolas" Margin="0,0,0,6"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="区　域" Foreground="#99FFFFFF" FontSize="12" Margin="0,0,16,6"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TxtRegion" Foreground="White" FontSize="13" FontFamily="Consolas" Margin="0,0,0,6"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="中　心" Foreground="#99FFFFFF" FontSize="12" Margin="0,0,16,0"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="TxtCenter" Foreground="White" FontSize="13" FontFamily="Consolas"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- 底部提示 -->
        <Border x:Name="BottomTip"
                Background="#CC000000"
                CornerRadius="20"
                Padding="20,8"
                Visibility="Collapsed">
            <TextBlock x:Name="BottomTipText"
                       Text="按 ESC 退出"
                       Foreground="#AAFFFFFF"
                       FontSize="14"
                       HorizontalAlignment="Center"/>
        </Border>
    </Canvas>
</Window>