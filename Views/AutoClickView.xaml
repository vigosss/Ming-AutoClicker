<UserControl x:Class="Ming_AutoClicker.Views.AutoClickView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 设置区域 -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="8"
                Padding="24"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                IsEnabled="{Binding IsNotRunning}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.06" Color="#000000"/>
            </Border.Effect>
            <StackPanel>
                <!-- 点击类型 -->
                <TextBlock Text="点击类型" Style="{StaticResource SectionTitleText}" Margin="0,0,0,12"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                    <RadioButton Content="鼠标左键"
                                 Style="{StaticResource ModernRadioButton}"
                                 IsChecked="{Binding IsLeftButton, Mode=TwoWay}"
                                 GroupName="ClickButton"/>
                    <RadioButton Content="鼠标中键"
                                 Style="{StaticResource ModernRadioButton}"
                                 IsChecked="{Binding IsMiddleButton, Mode=TwoWay}"
                                 GroupName="ClickButton"/>
                    <RadioButton Content="鼠标右键"
                                 Style="{StaticResource ModernRadioButton}"
                                 IsChecked="{Binding IsRightButton, Mode=TwoWay}"
                                 GroupName="ClickButton"/>
                </StackPanel>

                <!-- 分隔线 -->
                <Border Background="{StaticResource BorderBrush}" Height="1" Margin="0,0,0,24"/>

                <!-- 点击间隔 -->
                <TextBlock Text="点击间隔" Style="{StaticResource SectionTitleText}" Margin="0,0,0,12"/>
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding IntervalText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}"
                             Height="36"
                             FontSize="14"
                             HorizontalContentAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               Text="毫秒 (ms)"
                               Style="{StaticResource BodyText}"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </Grid>

                <!-- 分隔线 -->
                <Border Background="{StaticResource BorderBrush}" Height="1" Margin="0,0,0,24"/>

                <!-- 快捷键提示 -->
                <Border Background="{StaticResource BorderLightBrush}"
                        CornerRadius="6"
                        Padding="16,10"
                        HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="{StaticResource SurfaceBrush}"
                                CornerRadius="4"
                                Padding="8,4"
                                Margin="0,0,8,0">
                            <TextBlock Text="F8"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}">
                            <Run Text="{Binding HotkeyHintText, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- 底部提示 -->
        <TextBlock Grid.Row="1"
                   Text="{Binding StatusText}"
                   Style="{StaticResource StatusText}"
                   Margin="0,8,0,0"/>
    </Grid>
</UserControl>