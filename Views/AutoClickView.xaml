<UserControl x:Class="Ming_AutoClicker.Views.AutoClickView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="🖱 鼠标连点" Style="{StaticResource PageTitleText}" Margin="0,0,0,16"/>

        <!-- 设置区域 -->
        <Border Grid.Row="1"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="8"
                Padding="24"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top">
            <Border.Effect>
                <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.06" Color="#000000"/>
            </Border.Effect>
            <StackPanel>
                <!-- 点击类型 -->
                <TextBlock Text="点击类型" Style="{StaticResource SectionTitleText}" Margin="0,0,0,12"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                    <RadioButton Content="鼠标左键"
                                 Style="{StaticResource ModernRadioButton}"
                                 IsChecked="{Binding IsLeftButton, Mode=TwoWay}"
                                 GroupName="ClickButton"/>
                    <RadioButton Content="鼠标中键"
                                 Style="{StaticResource ModernRadioButton}"
                                 IsChecked="{Binding IsMiddleButton, Mode=TwoWay}"
                                 GroupName="ClickButton"/>
                    <RadioButton Content="鼠标右键"
                                 Style="{StaticResource ModernRadioButton}"
                                 IsChecked="{Binding IsRightButton, Mode=TwoWay}"
                                 GroupName="ClickButton"/>
                </StackPanel>

                <!-- 分隔线 -->
                <Border Background="{StaticResource BorderBrush}" Height="1" Margin="0,0,0,24"/>

                <!-- 点击间隔 -->
                <TextBlock Text="点击间隔" Style="{StaticResource SectionTitleText}" Margin="0,0,0,12"/>
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding IntervalText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}"
                             Height="36"
                             FontSize="14"
                             HorizontalContentAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               Text="毫秒 (ms)"
                               Style="{StaticResource BodyText}"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </Grid>

                <!-- 分隔线 -->
                <Border Background="{StaticResource BorderBrush}" Height="1" Margin="0,0,0,24"/>

                <!-- 状态信息 -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="状态" Style="{StaticResource LabelText}"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding RunningStatusText}"
                               FontSize="13" FontWeight="Medium"
                               VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <TextBlock Grid.Column="3"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13" VerticalAlignment="Center">
                        <Run Text="已点击 "/><Run Text="{Binding ClickCount, Mode=OneWay}"/><Run Text=" 次"/>
                    </TextBlock>
                </Grid>

                <!-- 操作按钮 -->
                <Button HorizontalAlignment="Left"
                        MinWidth="160" Height="40"
                        FontSize="14" FontWeight="Medium"
                        Command="{Binding ToggleCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource BaseButton}">
                            <Setter Property="Content" Value="▶ F8 开始连点"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                    <Setter Property="Content" Value="■ F8 停止连点"/>
                                    <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextOnPrimaryBrush}"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>

        <!-- 底部提示 -->
        <TextBlock Grid.Row="2"
                   Text="{Binding StatusText}"
                   Style="{StaticResource StatusText}"
                   Margin="0,8,0,0"/>
    </Grid>
</UserControl>