<Window x:Class="Ming_AutoClicker.Views.RegionSelectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="区域截图"
        WindowStyle="None"
        Topmost="True"
        ResizeMode="NoResize"
        WindowState="Maximized"
        Background="Black"
        ShowInTaskbar="False"
        Focusable="True"
        Cursor="Cross">

    <Canvas x:Name="MainCanvas">
        <!-- 屏幕截图背景 -->
        <Image x:Name="BackgroundImage" Stretch="Fill"/>

        <!-- 半透明遮罩 -->
        <Path x:Name="OverlayPath" Fill="#99000000"/>

        <!-- 选区边框 -->
        <Rectangle x:Name="SelectionRect"
                   Stroke="#FF409CFF"
                   StrokeThickness="2"
                   Visibility="Collapsed"/>

        <!-- 尺寸信息 -->
        <Border x:Name="InfoPanel"
                Background="#CC000000"
                CornerRadius="3"
                Padding="8,4"
                Visibility="Collapsed">
            <TextBlock x:Name="SizeText" Foreground="White" FontSize="12" FontFamily="Consolas"/>
        </Border>

        <!-- 提示文字 -->
        <TextBlock x:Name="TipText"
                   Text="按住鼠标左键拖拽选择截图区域，按 ESC 取消"
                   Foreground="White"
                   FontSize="16"
                   Opacity="0.8"/>
    </Canvas>
</Window>