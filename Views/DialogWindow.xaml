<Window x:Class="Ming_AutoClicker.Views.DialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        Width="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">

    <Border Background="{StaticResource SurfaceBrush}"
            CornerRadius="12"
            Margin="12"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.15" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- 标题栏 -->
                <RowDefinition Height="Auto"/>   <!-- 内容区 -->
                <RowDefinition Height="Auto"/>   <!-- 按钮区 -->
            </Grid.RowDefinitions>

            <!-- 标题栏（可拖动） -->
            <Border Grid.Row="0"
                    x:Name="TitleBar"
                    CornerRadius="12,12,0,0"
                    Padding="20,14"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 图标 -->
                    <TextBlock Grid.Column="0"
                               x:Name="IconText"
                               FontSize="20"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"/>

                    <!-- 标题文字 -->
                    <TextBlock Grid.Column="1"
                               x:Name="TitleText"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="White"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- 消息内容 -->
            <TextBlock Grid.Row="1"
                       x:Name="MessageText"
                       TextWrapping="Wrap"
                       FontSize="13"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Padding="24,20"
                       LineHeight="20"/>

            <!-- 按钮区 -->
            <Border Grid.Row="2"
                    Background="{StaticResource StatusBarBrush}"
                    CornerRadius="0,0,12,12"
                    Padding="20,14"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{StaticResource BorderBrush}">
                <StackPanel x:Name="ButtonPanel"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"/>
            </Border>
        </Grid>
    </Border>
</Window>
</write_to_file>
