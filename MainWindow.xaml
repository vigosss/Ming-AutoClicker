<Window x:Class="Ming_AutoClicker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Ming_AutoClicker.Views"
        Title="鼠标宏"
        Width="680"
        Height="520"
        MinWidth="580"
        MinHeight="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 内容区域 -->
        <ContentControl x:Name="ContentArea" Grid.Row="0" Margin="8">
            <ContentControl.Content>
                <views:MacroListView x:Name="MacroListView"/>
            </ContentControl.Content>
        </ContentControl>

        <!-- 底部状态栏 -->
        <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0" Background="#F5F5F5" Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 执行状态指示 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,16,0">
                    <Ellipse x:Name="StatusIndicator" Width="8" Height="8" Fill="Gray" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding ExecutionStatus}" FontSize="12" Foreground="#666"/>
                </StackPanel>

                <!-- 分隔线 -->
                <Border Grid.Column="1" Width="1" Background="#D0D0D0" Margin="0,2,16,2"/>

                <!-- 状态消息 -->
                <TextBlock Grid.Column="2" Text="{Binding StatusMessage}" FontSize="12" Foreground="#666"
                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>

                <!-- F8 提示 -->
                <TextBlock Grid.Column="3" Text="F8 开始/停止" FontSize="11" Foreground="#999"
                           VerticalAlignment="Center" Margin="8,0,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>