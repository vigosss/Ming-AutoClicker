<Window x:Class="Ming_AutoClicker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Ming_AutoClicker.Views"
        Title="智点精灵"
        Width="700"
        Height="560"
        MinWidth="600"
        MinHeight="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{StaticResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 内容区域 -->
        <ContentControl x:Name="ContentArea" Grid.Row="0" Margin="16,12,16,8">
            <ContentControl.Content>
                <views:MacroListView x:Name="MacroListView"/>
            </ContentControl.Content>
        </ContentControl>

        <!-- 底部状态栏 -->
        <Border Grid.Row="1"
                Background="{StaticResource StatusBarBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{StaticResource BorderBrush}"
                Padding="16,8"
                CornerRadius="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 执行状态指示 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,16,0" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusIndicator"
                             Width="8" Height="8"
                             Fill="{StaticResource TextDisabledBrush}"
                             Margin="0,0,8,0"
                             VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ExecutionStatus}" Style="{StaticResource StatusText}"/>
                </StackPanel>

                <!-- 分隔线 -->
                <Border Grid.Column="1" Width="1" Background="{StaticResource BorderBrush}" Margin="0,2,16,2"/>

                <!-- 状态消息 -->
                <TextBlock Grid.Column="2"
                           Text="{Binding StatusMessage}"
                           Style="{StaticResource StatusText}"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center"/>

                <!-- F8 提示 -->
                <Border Grid.Column="3"
                        Background="{StaticResource BorderLightBrush}"
                        CornerRadius="4"
                        Padding="8,3">
                    <TextBlock Text="F8 开始/停止"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>